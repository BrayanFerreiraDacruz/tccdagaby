# ============================================================
#  Study Time - Configuração de ambiente
#  Copie este arquivo para ".env" e ajuste conforme necessário
# ============================================================

# Chave secreta usada para assinar os tokens JWT (troque em produção)
SECRET_KEY=troque-esta-chave-secreta-em-producao

# --- Banco de dados ---
# Deixe USE_MYSQL=true para usar o MySQL do XAMPP (conforme o TCC).
# Se o MySQL não estiver disponível, o sistema usa SQLite automaticamente,
# permitindo rodar o projeto sem configuração extra.
USE_MYSQL=true

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=study_time

# --- API oficial de questões do ENEM (ENEM.dev) ---
ENEM_API_BASE=https://api.enem.dev/v1

# Porta do servidor Flask
PORT=5000
